  {
    "year": 2002,
    "name": "Osterrock Festival 2002",
    "era": "osterrock",
    "location": "Lücken/Liener bei Lindern",
    "date": "1. April 2002 (Ostermontag)",
    "poster": "/images/historie/2002.jpg",
    "description": "Das Osterrock 2002 ging am Ostermontag, dem 1. April 2002, im Lücken Liener über die Bühne und bot einen entspannten, durchgehend rockigen Konzertnachmittag. Mehrere Bands aus der Region standen auf dem Programm und spielten in umgekehrter Reihenfolge zum Line-up auf dem Plakat.",
    "bands": [
      { "name": "Subspecial", "genre": "Meppen", "description": "Subspecial eröffneten das Festival mit einem melodischen, aber druckvollen Rock-Set. Die Band brachte das Publikum schnell auf Betriebstemperatur und sorgte für einen gelungenen Start in den Nachmittag." },
      { "name": "Slope", "genre": "Oldenburg", "description": "Anschließend übernahmen Slope und lieferten einen energiegeladenen Auftritt mit ihrem Crossover-Sound. Vor der Bühne wurde es deutlich lebendiger, und die Mischung aus Groove und Hardcore-Elementen kam besonders gut an." },
      { "name": "Civil Courage", "genre": "Lähden", "description": "Civil Courage hielten das Energielevel hoch und präsentierten einen raueren, härteren Sound. Ihre Songs wirkten direkt und kraftvoll, und die Band überzeugte mit intensiver Bühnenpräsenz." },
      { "name": "Alienated", "genre": "Lindern", "description": "Alienated hatte ein Heimspiel und schlossen das Festival mit schnellem, melodischem Punkrock ab. Ihr Auftritt war laut, dynamisch und brachte zum Abschluss noch einmal ordentlich Bewegung in den Saal." }

  {
    "year": 2004,
    "name": "Osterrock Festival 2004",
    "era": "osterrock",
    "location": "Lücken/Liener bei Lindern",
    "date": "12. April 2004",
    "poster": "/images/historie/2004.jpg",
    "description": "Das Osterrock 2004 ging am 12. April 2004 in Lücken/Liener bei Lindern über die Bühne und fühlte sich wie ein langer, lauter Rock-Feiertag an: kalte Getränke, volle Halle und eine Band nach der anderen, die das Tempo immer weiter hochschraubte, bis am Ende alles nach Rock 'n' Roll roch.",
    "bands": [
      { "name": "Bandcontest-Gewinner", "genre": "", "description": "Der Bandcontest-Gewinner eröffnete den Nachmittag mit ordentlich Spielfreude und sichtbar Bock auf die Bühne. Trotz frühem Slot legten sie sich richtig rein und holten sofort die ersten Fans nach vorne. Ein gelungener Start, der die Richtung für den restlichen Tag vorgab." },
      { "name": "D-Fakt", "genre": "Löninger Crossover", "description": "D-Fakt schoben danach einen fetten Crossover-Sound hinterher. Harte Gitarren, treibende Beats und viel Bewegung auf der Bühne sorgten dafür, dass es vor den Boxen deutlich lebendiger wurde. Die Menge kam langsam richtig in Fahrt." },
      { "name": "Boozed", "genre": "Highspeed Rock 'n' Roll", "description": "Boozed drückten das Gaspedal dann komplett durch und lieferten schnellen, dreckigen Highspeed-Rock 'n' Roll. Ihr Set war laut, rotzig und genau das Richtige, um die Stimmung endgültig Richtung Party zu drehen." },
      { "name": "V8 Wankers", "genre": "Offenbacher Schweinerock", "description": "Die V8 Wankers legten mit ihrem rauen Schweinerock noch eine Schippe drauf. Fette Riffs, viel Attitüde und ein Sound, der direkt in die Magengrube ging, machten ihren Auftritt zu einem der lautesten Momente des Tages." },
      { "name": "Ghouls", "genre": "Misfits-Coverband", "description": "Zum Finale übernahmen die Ghouls und verwandelten die Halle in eine Horror-Punk-Party. Misfits-Klassiker wurden lautstark mitgesungen, und die Band hielt die Energie bis zum letzten Song ganz oben." }
    ],

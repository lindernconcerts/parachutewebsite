---
import PageLayout from '@/layouts/PageLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import galleryData from '@/data/gallery.json';

const sorted = [...galleryData].sort((a, b) => b.year - a.year);
---

<PageLayout
  title="Galerie"
  description="Bilder vom Parachute Festival – alle Galerien der vergangenen Jahre auf Google Photos."
>
  <!-- Page Header -->
  <section
    class="py-12 md:py-20 text-center relative"
    style="background: var(--color-bg-section); border-bottom: 1px solid var(--color-border);"
  >
    <div class="container">
      <p class="eyebrow mb-4">Unvergessliche Momente</p>
      <h1 class="font-heading text-4xl sm:text-6xl md:text-8xl text-white">Galerie</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Jahrgänge"
        title="Alle Galerien"
        subtitle="Zwei Vorschaubilder pro Jahr – die komplette Galerie öffnet sich bei Google Photos."
      />

      <div class="space-y-10">
        {sorted.map(gallery => (
          <div class="card overflow-hidden">
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-0">

              <!-- Preview Images -->
              <div class="grid grid-cols-2 gap-1 p-1" style="background: var(--color-bg-card);">
                {gallery.previews.map((src, i) => (
                  <div
                    class="relative overflow-hidden flex items-center justify-center"
                    style="aspect-ratio: 4/3; background: var(--color-dark);"
                  >
                    <img
                      src={src}
                      alt={`${gallery.title} – Vorschau ${i + 1}`}
                      loading="lazy"
                      class="w-full h-full object-cover"
                      onerror="this.parentElement.innerHTML='<span class=\'font-heading text-6xl opacity-10 text-primary\'>" + gallery.year + "</span>'"
                    />
                  </div>
                ))}
              </div>

              <!-- Info + CTA -->
              <div
                class="flex flex-col justify-between p-8 shrink-0 lg:w-72 border-t border-[var(--color-border)] lg:border-t-0 lg:border-l"
                style="background: var(--color-bg-card);"
              >
                <div>
                  <span class="font-heading text-6xl text-primary leading-none block mb-2">
                    {gallery.year}
                  </span>
                  <h3 class="font-heading text-2xl text-white mb-3">{gallery.title}</h3>
                  <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
                    {gallery.description}
                  </p>
                </div>

                <a
                  href={gallery.googlePhotosUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-primary mt-6 text-center text-base"
                >
                  Alle Fotos ansehen
                </a>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

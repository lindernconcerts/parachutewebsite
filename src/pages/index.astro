---
import PageLayout from '@/layouts/PageLayout.astro';
import Hero from '@/components/home/Hero.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import bandsData from '@/data/bands.json';

const bandsById = new Map(bandsData.map(b => [b.id, b]));

const lineup2026Raw = [
  {
    id: 'rogers',
    name: 'Rogers',
    role: 'Headliner',
    genre: 'Punkrock',
    origin: '',
    image: '/images/bands/rogers.jpg',
    description:
      'Die Düsseldorfer Punkrock-Legende kommt nach Lindern! Nach einem erfolgreichen Festivalsommer und dem Chart-Erfolg von „Rambazamba & Randale" bringen Rogers genau die explosive Live-Energie auf unsere Bühne, für die sie seit Jahren bekannt sind. Unter dem Motto „Das war ein geiler Abend!" schaffen sie unvergessliche Konzertmomente voller Leidenschaft, Schweiß und ehrlichem Punkrock.',
    links: {
      instagram: 'https://www.instagram.com/rogersband/',
      spotify: 'https://open.spotify.com/artist/rogers',
    },
    highlight: true,
  },
  {
    id: 'farewell-spit',
    name: 'Farewell Spit',
    role: 'Support',
    genre: 'Rock / Metal',
    origin: '',
    image: '/images/bands/farewell-spit.jpg',
    description:
      'Farewell Spit spricht für all diejenigen, die sich in einer Welt voller Herausforderungen verloren fühlen. Ihre Musik – eine Mischung aus Rock, poppigen Elektro-Parts und Metal-Sound – umhüllt die Seele mit Trost und Freude. Jeder Song erzählt eine emotionale Geschichte vom unaufhörlichen Drang der Veränderung und der Selbstfindung.',
    links: {},
    highlight: false,
  },
  {
    id: 'liebe-3000',
    name: 'Liebe 3000',
    role: 'Support',
    genre: 'Pop / Rock',
    origin: '',
    image: '/images/bands/liebe-3000.jpg',
    description:
      'Ali Amore, Malibu Markus, Schiessbuden Bernie, Michi Moschus und Andi Acapulco reiten souverän die Sinuswelle der Romantik. Liebe 3000 ist musikalische Begehrlichkeit: Ohrwurm-Hits mit der Extraportion Herz. Unkomplizierte Arrangements treffen auf ehrliche Worte – und ein Lächeln für alle inklusive.',
    links: {},
    highlight: false,
  },
  {
    id: 'drauf',
    name: 'DRAUF',
    role: 'Support',
    genre: 'Punk Rock',
    origin: '',
    image: '/images/bands/drauf.jpg',
    description:
      'Deutschsprachiger Punk Rock, der direkt ins Ohr und mitten ins Herz geht. Seit 2017 machen sie klar: Kein Platz für rechte Parolen – stattdessen klare Kante gegen Faschismus, Gesellschaftskritik und ganz viel Spaß. Mit ihrem aktuellen Album „Sternzeichen Zigarette" (Oktober 2024) zeigen sie einmal mehr wofür DRAUF stehen: laut sein, Haltung zeigen, gemeinsam feiern.',
    links: {},
    highlight: false,
  },
];

const lineup2026 = lineup2026Raw.map(band => ({
  ...band,
  links: bandsById.get(band.id)?.links ?? band.links,
}));
---

<PageLayout
  title="Parachute Festival"
  description="Kein Kommerz, kein Schnickschnack – das Parachute Festival Lindern. Ehrlicher Rock, ehrenamtlich organisiert, von der Community getragen. Am 24. April 2027 in Lindern (Oldenburg)."
  heroFullBleed={true}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "MusicEvent",
    "name": "Parachute Festival 2027",
    "description": "Ehrenamtliches Rockfestival in Lindern (Oldenburg). Non-profit, handgemacht, seit 2000.",
    "startDate": "2027-04-24T17:00:00+02:00",
    "endDate": "2027-04-25T02:00:00+02:00",
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "location": {
      "@type": "Place",
      "name": "Schützenplatz Lindern",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Am Schützenpl.",
        "addressLocality": "Lindern",
        "postalCode": "49699",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 52.8446,
        "longitude": 7.7671
      }
    },
    "organizer": {
      "@type": "Organization",
      "name": "Projektunterstützungsverein Lindern e.V.",
      "url": "https://parachutefestival.de",
      "email": "lindernconcerts@gmail.com"
    },
    "performer": [
      { "@type": "MusicGroup", "name": "Rogers" },
      { "@type": "MusicGroup", "name": "Farewell Spit" },
      { "@type": "MusicGroup", "name": "Liebe 3000" },
      { "@type": "MusicGroup", "name": "DRAUF" }
    ],
    "offers": {
      "@type": "Offer",
      "url": "https://parachutefestival.de/tickets",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "EUR"
    },
    "image": "https://parachutefestival.de/images/Logo.png",
    "url": "https://parachutefestival.de"
  }}
>
  <!-- Hero + Countdown -->
  <Hero />

  <!-- Highlights Strip -->
  <section style="background: var(--color-primary);">
    <div class="container py-5">
      <div class="flex flex-wrap justify-center gap-6 md:gap-14 text-center">
        {[
          { icon: '🎸', label: 'Live Bands' },
          { icon: '🍺', label: 'Kalte Drinks' },
          { icon: '🤘', label: 'Non Profit' },
          { icon: '📍', label: 'Lindern (Oldenburg)' },
        ].map(({ icon, label }) => (
          <div class="flex items-center gap-2">
            <span class="text-2xl" aria-hidden="true">{icon}</span>
            <span class="font-heading text-xl text-black tracking-widest uppercase">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro Text -->
  <section class="section">
    <div class="container max-w-4xl text-center">
      <p class="eyebrow mb-6">Was wir sind</p>
      <h2 class="font-heading text-5xl md:text-7xl text-white mb-8 leading-none">
        DIY statt Konzern.<br />
        <span style="color: var(--color-primary);">Leidenschaft</span> statt Profit.
      </h2>
      <div class="space-y-5 text-left md:text-center">
        <p class="text-base md:text-lg leading-relaxed" style="color: var(--color-text-muted);">
          Kein Kommerz, kein Schnickschnack – das Parachute Festival Lindern ist ehrlicher Rock,
          handgemacht in Lindern (Oldenburg). Ehrenamtlich organisiert, von der Community getragen
          und mit jeder Menge Herzblut auf die Beine gestellt, steht unser Festival für genau das,
          was in der Szene manchmal fehlt: <span class="text-white font-semibold">Authentizität.</span>
        </p>
        <p class="text-base md:text-lg leading-relaxed" style="color: var(--color-text-muted);">
          Hier zählt nicht, wie groß dein Name auf dem Plakat ist, sondern wie sehr du die Bühne
          zum Beben bringst. Mit regionalen und nationalen Rockbands, kurzen Wegen, kalten Drinks
          und einer familiären Crowd feiern wir jedes Jahr ein Festival, das bewusst anders ist.
        </p>
        <p class="text-lg md:text-xl font-semibold text-white">
          Am 24. April 2027 ist es wieder so weit.
        </p>
        <p class="text-base" style="color: var(--color-primary);">
          #NonProfit 🤘
        </p>
      </div>
    </div>
  </section>

  <!-- Lineup 2026 -->
  <section class="section" style="background: var(--color-bg-section);">
    <div class="container">
      <SectionHeading
        eyebrow="Lineup 2026"
        title="Die Bands"
        subtitle="Diese Künstler brachten am 25. April 2026 den Schützenplatz Lindern zum Beben."
      />

      <!-- Headliner -->
      {lineup2026.filter(b => b.highlight).map(band => (
        <div
          class="mb-10 rounded-sm overflow-hidden"
          style="border: 2px solid var(--color-primary); box-shadow: 0 0 40px var(--color-glow);"
        >
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <!-- Image placeholder -->
            <div
              class="relative aspect-video lg:aspect-auto flex items-center justify-center"
              style="background: var(--color-bg-card); min-height: 280px;"
            >
              <img
                src={band.image}
                alt={band.name}
                loading="lazy"
                class="w-full h-full object-cover absolute inset-0"
                onerror="this.style.display='none'"
              />
              <span class="font-heading text-8xl md:text-9xl relative z-10 opacity-10 text-primary select-none">
                {band.name[0]}
              </span>
            </div>

            <!-- Content -->
            <div class="p-8 md:p-10 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-4">
                <span class="badge-primary">Headliner</span>
                <span class="badge-secondary">{band.genre}</span>
                {band.origin && (
                  <span class="text-sm" style="color: var(--color-text-muted);">📍 {band.origin}</span>
                )}
              </div>
              <h3 class="font-heading text-6xl md:text-7xl text-white mb-5">{band.name}</h3>
              <p class="text-base leading-relaxed mb-6" style="color: var(--color-text-muted);">
                {band.description}
              </p>
              {Object.values(band.links).some(Boolean) && (
                <div class="flex gap-4 mb-6">
                  {band.links.spotify && (
                    <a href={band.links.spotify} target="_blank" rel="noopener noreferrer" aria-label="Spotify" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                    </a>
                  )}
                  {band.links.instagram && (
                    <a href={band.links.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                  )}
                  {band.links.facebook && (
                    <a href={band.links.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                  )}
                  {band.links.youtube && (
                    <a href={band.links.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                  )}
                  {band.links.website && (
                    <a href={band.links.website} target="_blank" rel="noopener noreferrer" aria-label="Website" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  )}
                </div>
              )}
              <p class="text-sm font-semibold" style="color: var(--color-primary);">
                Es wird laut. Es wird wild. Und es wird garantiert ein geiler Abend. 🤘
              </p>
            </div>
          </div>
        </div>
      ))}

      <!-- Support Acts -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {lineup2026.filter(b => !b.highlight).map(band => (
          <div class="card flex flex-col">
            <!-- Image placeholder -->
            <div
              class="relative aspect-video flex items-center justify-center overflow-hidden"
              style="background: var(--color-bg-card);"
            >
              <img
                src={band.image}
                alt={band.name}
                loading="lazy"
                class="w-full h-full object-cover absolute inset-0"
                onerror="this.style.display='none'"
              />
              <span class="font-heading text-6xl opacity-10 text-secondary select-none relative z-10">
                {band.name[0]}
              </span>
            </div>

            <div class="p-6 flex flex-col flex-1">
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="badge-secondary">{band.genre}</span>
                {band.origin && (
                  <span class="text-xs" style="color: var(--color-text-muted);">📍 {band.origin}</span>
                )}
              </div>
              <h3 class="font-heading text-3xl text-white mb-3">{band.name}</h3>
              <p class="text-sm leading-relaxed flex-1" style="color: var(--color-text-muted);">
                {band.description}
              </p>
              {Object.values(band.links).some(Boolean) && (
                <div class="flex gap-3 mt-4 pt-4" style="border-top: 1px solid var(--color-border);">
                  {band.links.spotify && (
                    <a href={band.links.spotify} target="_blank" rel="noopener noreferrer" aria-label="Spotify" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                    </a>
                  )}
                  {band.links.instagram && (
                    <a href={band.links.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                  )}
                  {band.links.facebook && (
                    <a href={band.links.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                  )}
                  {band.links.youtube && (
                    <a href={band.links.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                  )}
                  {band.links.website && (
                    <a href={band.links.website} target="_blank" rel="noopener noreferrer" aria-label="Website" class="transition-colors hover:text-primary" style="color: var(--color-text-muted);">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/band-library" class="btn-outline">
          Alle Bands in der Band Library
        </a>
      </div>
    </div>
  </section>

  <!-- Tickets CTA -->
  <section class="section">
    <div class="container text-center">
      <SectionHeading
        eyebrow="Dabei sein"
        title="Tickets"
        subtitle="Sei dabei bevor es ausverkauft ist — das Parachute Festival macht sich schnell rar."
      />
      <a href="/tickets" class="btn-primary text-xl px-12 py-5">
        Jetzt Tickets sichern
      </a>
    </div>
  </section>
</PageLayout>

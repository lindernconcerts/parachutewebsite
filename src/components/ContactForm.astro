---
// Web3Forms access key: set PUBLIC_WEB3FORMS_KEY in Cloudflare env vars
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const isMisconfigured = !accessKey;
---

{isMisconfigured && (
  <div class="p-4 rounded-sm mb-6" style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.35);">
    <p class="text-sm" style="color: #f87171;">
      Das Kontaktformular ist momentan nicht verfügbar. Bitte schreib uns direkt per
      <a href="mailto:lindernconcerts@gmail.com" class="underline">E-Mail</a>.
    </p>
  </div>
)}

<form
  id="contact-form"
  class="space-y-6"
  novalidate
>
  <!-- Web3Forms fields -->
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="subject" value="Kontaktanfrage — Parachute Festival" />
  <input type="hidden" name="from_name" value="Parachute Festival Website" />
  <input type="hidden" name="redirect" value="false" />
  <!-- Honeypot -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Name -->
    <div>
      <label for="cf-name" class="block text-sm font-semibold mb-2 text-white">Name *</label>
      <input
        id="cf-name"
        name="name"
        type="text"
        required
        class="w-full px-4 py-3 rounded-sm bg-[var(--color-bg-card)] border text-white placeholder-[var(--color-text-muted)] focus:outline-none transition-colors"
        style="border-color: var(--color-border);"
        placeholder="Dein Name"
      />
    </div>

    <!-- E-Mail -->
    <div>
      <label for="cf-email" class="block text-sm font-semibold mb-2 text-white">E-Mail *</label>
      <input
        id="cf-email"
        name="email"
        type="email"
        required
        class="w-full px-4 py-3 rounded-sm bg-[var(--color-bg-card)] border text-white placeholder-[var(--color-text-muted)] focus:outline-none transition-colors"
        style="border-color: var(--color-border);"
        placeholder="deine@email.de"
      />
    </div>
  </div>

  <!-- Betreff -->
  <div>
    <label for="cf-subject" class="block text-sm font-semibold mb-2 text-white">Betreff *</label>
    <input
      id="cf-subject"
      name="subject_user"
      type="text"
      required
      class="w-full px-4 py-3 rounded-sm bg-[var(--color-bg-card)] border text-white placeholder-[var(--color-text-muted)] focus:outline-none transition-colors"
      style="border-color: var(--color-border);"
      placeholder="Worum geht's?"
    />
  </div>

  <!-- Nachricht -->
  <div>
    <label for="cf-message" class="block text-sm font-semibold mb-2 text-white">Nachricht *</label>
    <textarea
      id="cf-message"
      name="message"
      required
      rows="6"
      class="w-full px-4 py-3 rounded-sm bg-[var(--color-bg-card)] border text-white placeholder-[var(--color-text-muted)] focus:outline-none transition-colors resize-y"
      style="border-color: var(--color-border);"
      placeholder="Schreib uns, was dich bewegt..."
    ></textarea>
  </div>

  <!-- Submit -->
  <div class="flex items-center gap-4">
    <button type="submit" id="cf-submit" class="btn-primary" disabled={isMisconfigured}>
      Nachricht senden
    </button>
    <span id="cf-status" class="text-sm hidden"></span>
  </div>
</form>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const submit  = document.getElementById('cf-submit') as HTMLButtonElement;
  const status  = document.getElementById('cf-status')!;

  // Live border highlight on focus
  form.querySelectorAll('input, textarea').forEach(el => {
    el.addEventListener('focus', () => (el as HTMLElement).style.borderColor = 'var(--color-primary)');
    el.addEventListener('blur',  () => (el as HTMLElement).style.borderColor = 'var(--color-border)');
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submit.disabled = true;
    submit.textContent = 'Wird gesendet...';
    status.className = 'text-sm hidden';

    try {
      const data = Object.fromEntries(new FormData(form));
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await response.json();

      if (json.success) {
        status.textContent = '✓ Nachricht gesendet! Wir melden uns bald.';
        status.className   = 'text-sm text-[var(--color-secondary)]';
        form.reset();
      } else {
        throw new Error(json.message || 'Fehler beim Senden');
      }
    } catch (err) {
      status.textContent = '✗ Fehler beim Senden. Bitte versuch es erneut oder schreib uns direkt per E-Mail.';
      status.className   = 'text-sm text-red-400';
    } finally {
      submit.disabled    = false;
      submit.textContent = 'Nachricht senden';
      status.classList.remove('hidden');
    }
  });
</script>

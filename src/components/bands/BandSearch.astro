---
import type { Band } from './types';

interface Props {
  bands: Band[];
}

const { bands } = Astro.props;

// Sorted alphabetically
const sorted = [...bands].sort((a, b) => a.name.localeCompare(b.name, 'de'));

// Unique first letters
const letters = [...new Set(sorted.map(b => b.name[0].toUpperCase()))].sort();
---

<!-- Band data for client-side search -->
<script id="band-data" type="application/json" set:html={JSON.stringify(sorted)} />

<!-- Search + A-Z Controls -->
<div class="mb-10">
  <!-- Search input -->
  <div class="relative max-w-xl mx-auto mb-8">
    <svg
      class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 pointer-events-none"
      style="color: var(--color-text-muted);"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input
      id="band-search-input"
      type="search"
      placeholder="Band suchen..."
      class="w-full pl-12 pr-4 py-4 rounded-sm font-body text-white placeholder-[var(--color-text-muted)] bg-[var(--color-bg-card)] border focus:outline-none transition-colors"
      style="border-color: var(--color-border);"
      autocomplete="off"
    />
  </div>

  <!-- A-Z Jump -->
  <div class="flex flex-wrap justify-center gap-1" id="az-nav">
    <button
      class="az-btn w-8 h-8 text-sm font-bold rounded transition-colors"
      data-letter="all"
      style="background: var(--color-primary); color: white;"
    >
      Alle
    </button>
    {letters.map(letter => (
      <button
        class="az-btn w-8 h-8 text-sm font-bold rounded transition-colors"
        data-letter={letter}
        style="background: var(--color-bg-card); color: var(--color-text-muted);"
      >
        {letter}
      </button>
    ))}
  </div>
</div>

<!-- Results info -->
<p id="band-results-info" class="text-sm mb-6" style="color: var(--color-text-muted);">
  {bands.length} Bands
</p>

<!-- Band Grid -->
<div id="band-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
  {sorted.map(band => (
    <div
      class="band-card-wrapper"
      data-name={band.name.toLowerCase()}
      data-letter={band.name[0].toUpperCase()}
      data-genres={band.genre.join(' ').toLowerCase()}
      data-bio={band.bio.toLowerCase()}
    >
      <slot name={band.id} />
    </div>
  ))}
</div>

<!-- No results -->
<p
  id="band-no-results"
  class="hidden text-center py-16 text-lg"
  style="color: var(--color-text-muted);"
>
  Keine Bands gefunden. Versuch's mit einem anderen Suchbegriff!
</p>

<script>
  import Fuse from 'fuse.js';

  const rawData = document.getElementById('band-data');
  if (!rawData) throw new Error('band-data not found');

  type Band = { id: string; name: string; genre: string[]; bio: string; active: boolean };
  const bands: Band[] = JSON.parse(rawData.textContent || '[]');

  const fuse = new Fuse(bands, {
    keys: [
      { name: 'name',  weight: 0.6 },
      { name: 'genre', weight: 0.2 },
      { name: 'bio',   weight: 0.2 },
    ],
    threshold: 0.35,
    minMatchCharLength: 2,
    includeScore: true,
  });

  const input      = document.getElementById('band-search-input') as HTMLInputElement;
  const grid       = document.getElementById('band-grid')!;
  const noResults  = document.getElementById('band-no-results')!;
  const resultsInfo = document.getElementById('band-results-info')!;
  const azButtons  = document.querySelectorAll<HTMLButtonElement>('.az-btn');

  let currentLetter = 'all';
  let currentQuery  = '';

  function applyFilters() {
    const wrappers = grid.querySelectorAll<HTMLElement>('.band-card-wrapper');
    let visible = 0;

    let matchingIds: Set<string> | null = null;

    if (currentQuery.length >= 2) {
      const results = fuse.search(currentQuery);
      matchingIds = new Set(results.map(r => r.item.id));
    }

    wrappers.forEach(wrapper => {
      const letter  = wrapper.dataset.letter!;
      const name    = wrapper.dataset.name!;
      const id      = wrapper.querySelector('[data-band-id]')?.getAttribute('data-band-id') ?? name;

      let show = true;

      // Letter filter
      if (currentLetter !== 'all' && letter !== currentLetter) show = false;

      // Search filter
      if (matchingIds !== null) {
        // Use name match as fallback since wrapper doesn't carry ID easily
        const inResults = [...matchingIds].some(mid => {
          const b = bands.find(b => b.id === mid);
          return b && name === b.name.toLowerCase();
        });
        if (!inResults) show = false;
      }

      wrapper.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.classList.toggle('hidden', visible > 0);
    resultsInfo.textContent = `${visible} Band${visible !== 1 ? 's' : ''}`;
  }

  input.addEventListener('input', () => {
    currentQuery = input.value.trim();
    if (currentQuery.length > 0) {
      currentLetter = 'all';
      azButtons.forEach(btn => {
        if (btn.dataset.letter === 'all') {
          btn.style.background = 'var(--color-primary)';
          btn.style.color = 'white';
        } else {
          btn.style.background = 'var(--color-bg-card)';
          btn.style.color = 'var(--color-text-muted)';
        }
      });
    }
    applyFilters();
  });

  azButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      currentLetter = btn.dataset.letter!;
      currentQuery = '';
      input.value = '';

      azButtons.forEach(b => {
        b.style.background = b === btn ? 'var(--color-primary)' : 'var(--color-bg-card)';
        b.style.color       = b === btn ? 'white'                : 'var(--color-text-muted)';
      });

      applyFilters();
    });
  });
</script>
